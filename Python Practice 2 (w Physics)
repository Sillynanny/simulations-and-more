# The goal for this simulation is to model the motion and velocity of an object with mass m under LINEAR air drag using simple Euler integration. Additionally, I'm aiming to model the conversion of energy within this system, and hopefully I'll analyze that the total mechanical energy in the system does NOT stay constant (it should decrease), as the nonconservative force of friction acts on the object. I will also model the power of the drag force, which should be negative if done right. I will model these physical concepts in this system by plotting them in simple time vs. concept graphs using matplotlib and numpy, and I will also answer some questions related to the sim, like what happens to the total mechanical energy and what happens to the velocity as time goes on.

# Let's say the object has mass 1 kg, and it is thrown from a 50 m building at an initial velocity 20 m/s at an angle of 45 degrees. If we're using linear drag, then the force of drag will be F_d = -bv, b=.5 N*s/m. As per usual, the gravity constant is g=9.8.
%matplotlib notebook
%matplotlib inline
import numpy as np
import matplotlib.pyplot as plt
#changes from previous sim: we are NOT importing math and sympy as they are useless for the sim
print("Units: kg, m, s")
m=1
g=9.8
b=.5
launch_angle=45*np.pi/180
v0=20
N=700
h=.01
h0=50
t=[]
a_x=[]
a_y=[]
v_x=[]
v_y=[]
h_x=[]
h_y=[]
v_x0=v0*np.cos(launch_angle)
v_y0=v0*np.sin(launch_angle)
h_x0=0
h_y0=h0
v_x.append(v_x0)
v_y.append(v_y0)
h_x.append(h_x0)
h_y.append(h_y0)
for n in range(N):
    a_x0=(-b/m)*v_x[n]
    a_y0=-g+(-b/m)*v_y[n]
    v_x_new=v_x[n]+h*a_x0
    v_y_new=v_y[n]+h*a_y0
    h_x_new=h_x[n]+h*v_x_new
    h_y_new=h_y[n]+h*v_y_new
    a_x.append(a_x0)
    a_y.append(a_y0)
    v_x.append(v_x_new)
    v_y.append(v_y_new)
    h_x.append(h_x_new)
    h_y.append(h_y_new)
    if h_y_new<0:
        break
for n in range(len(h_y)):
    t_new=h*n
    t.append(t_new)
print("Plot 1: Position of Object: Vertical Position vs. Horizontal Position")
plt.figure()
plt.scatter(h_x,h_y)
plt.xlabel("Horizontal Position")
plt.ylabel("Vertical Position")
plt.axhline(y=0, color='k')
plt.axvline(x=0, color='k')
plt.show()

print("Plot 2: Vertical Position vs. Time")
plt.figure()
plt.scatter(t,h_y)
plt.xlabel("Time")
plt.ylabel("Vertical Position")
plt.axhline(y=0, color='k')
plt.axvline(x=0, color='k')
plt.show()

print("Plot 3: Horizontal Position vs. Time")
plt.figure()
plt.scatter(t,h_x)
plt.xlabel("Time")
plt.ylabel("Horizontal Position")
plt.axhline(y=0, color='k')
plt.axvline(x=0, color='k')
plt.show()

print("Plot 4: Vertical Velocity vs. Time")
plt.figure()
plt.scatter(t,v_y)
plt.xlabel("Time")
plt.ylabel("Vertical Velocity")
plt.axhline(y=0, color='k')
plt.axvline(x=0, color='k')
plt.show()

print("Plot 5: Horizontal Velocity vs. Time")
plt.figure()
plt.scatter(t,v_x)
plt.xlabel("Time")
plt.ylabel("Horizontal Velocity")
plt.axhline(y=0, color='k')
plt.axvline(x=0, color='k')
plt.show()

#ok lets move on to energy now
K=[]
U=[]
E=[]
for i in range(len(h_y)):
    K_new=.5*m*(v_x[i]**2+v_y[i]**2)
    K.append(K_new)
    U_new=m*g*h_y[i]
    U.append(U_new)
    E_new=K_new+U_new
    E.append(E_new)
print("Plot 6: Kinetic Energy vs. Time")
plt.figure()
plt.scatter(t,K)
plt.xlabel("Time")
plt.ylabel("Kinetic Energy")
plt.axhline(y=0, color='k')
plt.axvline(x=0, color='k')
plt.show()

print("Plot 7: Potential Energy vs. Time")
plt.figure()
plt.scatter(t,U)
plt.xlabel("Time")
plt.ylabel("Potential Energy")
plt.axhline(y=0, color='k')
plt.axvline(x=0, color='k')
plt.show()

print("Plot 8: Total Mechanical Energy vs. Time")
plt.figure()
plt.scatter(t,E)
plt.xlabel("Time")
plt.ylabel("Total Mechanical Energy")
plt.axhline(y=0, color='k')
plt.axvline(x=0, color='k')
plt.show()

print("The total mechanical energy lost is:")
print(E[0]-E[-1])
print("The work done by nonconservative forces (drag) is:")
print(K[-1]-K[0]+U[-1]-U[0])

#ok now let's quickly do the power of drag
P_drag=[]
for i in range(len(v_y)):
    P_drag_new=-b*(v_x[i]**2+v_y[i]**2)
    P_drag.append(P_drag_new)

print("Plot 9: Drag Power vs. Time")
plt.figure()
plt.scatter(t,P_drag)
plt.xlabel("Time")
plt.ylabel("Power of Drag")
plt.axhline(y=0, color='k')
plt.axvline(x=0, color='k')
plt.show()


